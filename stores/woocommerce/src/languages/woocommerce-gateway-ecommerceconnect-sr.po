msgstr "https://ecconnect.upc.ua"

#. Description of the plugin
#: woocommerce-gateway-ecommerceconnect.php
msgid ""
"UPC WooCommerce plugin enables you to easily accept payments through your "
"Woocommerce store"
msgstr ""
"UPC WooCommerce додатак вам омогућава да лако прихватате плаћања путем ваше "
"Woocommerce продавнице"

#. Author of the plugin
#: woocommerce-gateway-ecommerceconnect.php
msgid "upc.ua"
msgstr "upc.ua"

#. Author URI of the plugin
#: woocommerce-gateway-ecommerceconnect.php
msgid "https://upc.ua"
msgstr "https://upc.ua"

