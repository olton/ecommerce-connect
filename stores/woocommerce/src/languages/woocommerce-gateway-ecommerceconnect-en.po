#. code shown in HTML.
msgid ""
"Send this link to a <a href=\"%1$s\" target=\"_blank\" rel=\"noopener "
"noreferrer\">UPC specialist</a> to return to the store after payment <span "
"style=\"color: red\"><pre><code>%2$s</code></pre></span>"
msgstr ""
"Send this link to a <a href=\"%1$s\" target=\"_blank\" rel=\"noopener "
"noreferrer\">UPC specialist</a> to return to the store after payment <span "
"style=\"color: red\"><pre><code>%2$s</code></pre></span>"

msgid "Gateway Disabled"
msgstr "Gateway Disabled"

#. translators: %1$s and %2$s are opening and closing anchor or <strong> tags.
msgid ""
"Choose UAH as your store currency in %1$sGeneral Settings%2$s to enable the "
"eCommerceCcnnect Gateway."
msgstr ""
"Choose UAH as your store currency in %1$s General Settings %2$s to enable the "
"eCommerceCcnnect Gateway."

msgid "Purchase"
msgstr "Purchase"

msgid "Back"
msgstr "Back"

msgid ""
"Thank you for your order, please click the button below to pay with "
"eCommerceConnect."
msgstr ""
"Thank you for your order, please click the button below to pay with "
"eCommerceConnect."

