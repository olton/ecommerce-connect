#. Plugin Name of the plugin
msgid "eCommerceConnect Gateway"
msgstr "eCommerceConnect Gateway"

#. Plugin URI of the plugin
msgid "https://ecconnect.upc.ua"
msgstr "https://ecconnect.upc.ua"

#. Description of the plugin
msgid ""
"UPC WooCommerce plugin enables you to easily accept payments through your "
"Woocommerce store"
msgstr "Az UPC WooCommerce bővítmény segítségével könnyen fogadhat fizetéseket a WooCommerce áruházában"

#. Author of the plugin
msgid "upc.ua"
msgstr "upc.ua"

#. Author URI of the plugin
msgid "https://upc.ua"
msgstr "https://upc.ua"

msgid "eCommerceConnect"
msgstr "eCommerceConnect"

msgid "WooCommerce eCommerceConnect Order Data"
msgstr "WooCommerce eCommerceConnect rendelési adatok"

msgid "WooCommerce eCommerceConnect Data"
msgstr "WooCommerce eCommerceConnect adatok"

#. translators: %1$s and %2$s are opening and closing anchor tags.
msgid ""
"By using this extension, you may be storing personal data or sharing data "
"with an external service. %1$sLearn more about how this works, including what "
"you may want to include in your privacy policy.%2$s"
msgstr "A bővítmény használatával személyes adatokat tárolhat vagy külső szolgáltatással oszthat meg adatokat. %1$sTudjon meg többet arról, hogyan működik ez, beleértve azt is, mit érdemes feltüntetni az adatvédelmi tájékoztatójában.%2$s"

msgid "Orders"
msgstr "Rendelések"

msgid "eCommerceConnect token"
msgstr "eCommerceConnect token"

msgid "eCommerceConnect Order Data Erased."
msgstr "Az eCommerceConnect rendelési adatai törölve."

#. translators: %1$s and %2$s are opening and closing <strong> tags.
msgid ""
"Accept card payments on your website via %1$seCommerceConnect%2$s payment "
"gateway"
msgstr "Fogadjon kártyás fizetéseket weboldalán a(z) %1$seCommerceConnect%2$s fizetési átjárón keresztül"

msgid "Enable/Disable"
msgstr "Engedélyezés/Letiltás"

msgid "Enable eCommerceConnect"
msgstr "eCommerceConnect engedélyezése"

msgid "This controls whether or not this gateway is enabled within WooCommerce."
msgstr "Ez szabályozza, hogy ez az átjáró engedélyezve van-e a WooCommerce-ben."

msgid "Title"
msgstr "Cím"

msgid "This controls the title which the user sees during checkout."
msgstr "Ez szabályozza a címet, amelyet a felhasználó fizetéskor lát."

msgid "Description"
msgstr "Leírás"

msgid "This controls the description which the user sees during checkout"
msgstr "Ez szabályozza a leírást, amelyet a felhasználó fizetéskor lát"

msgid "Payment Gateway Action URL"
msgstr "Fizetési átjáró műveleti URL"

msgid "e.g. https://ecg.test.upc.ua or https://secure.upc.ua"
msgstr "pl. https://ecg.test.upc.ua vagy https://secure.upc.ua"

msgid "eCommerceConnect Sandbox"
msgstr "eCommerceConnect tesztkörnyezet"

msgid "Place the payment gateway in test mode"
msgstr "Állítsa a fizetési átjárót teszt módba"

msgid "Merchant ID"
msgstr "Kereskedő azonosító"

msgid "This is the Merchant ID, received from eCommerceConnect"
msgstr "Ez az eCommerceConnect-től kapott kereskedő azonosító"

msgid "Terminal ID"
msgstr "Terminál azonosító"

msgid "This is the Terminal ID, received from eCommerceConnect"
msgstr "Ez az eCommerceConnect-től kapott terminál azonosító"

msgid "Private key"
msgstr "Privát kulcs"

msgid "This is the Private key, received from eCommerceConnect"
msgstr "Ez az eCommerceConnect-től kapott privát kulcs"

msgid "Private key for test mode"
msgstr "Privát kulcs teszt módhoz"

msgid "This is the Private key for test mode, received from eCommerceConnect"
msgstr "Ez az eCommerceConnect-től kapott privát kulcs teszt módhoz"

msgid "Work certificate"
msgstr "Éles tanúsítvány"

msgid ""
"This is the Work certificate for signature verification from UPC e-Commerce "
"Connect payment gateway"
msgstr "Ez az UPC e-Commerce Connect fizetési átjárótól kapott éles tanúsítvány az aláírás ellenőrzéséhez"

msgid "Test certificate"
msgstr "Teszt tanúsítvány"

msgid ""
"This is the Test certificate for signature verification from UPC e-Commerce "
"Connect payment gateway"
msgstr "Ez az UPC e-Commerce Connect fizetési átjárótól kapott teszt tanúsítvány az aláírás ellenőrzéséhez"

msgid "Status for Successful Withdrawal"
msgstr "Sikeres terhelés állapota"

msgid ""
"Set the current status of your WooCommerce order for the corresponding "
"transaction"
msgstr "Állítsa be a WooCommerce-rendelés aktuális állapotát a megfelelő tranzakcióhoz"

msgid "eCommerceConnect interface language"
msgstr "Az eCommerceConnect felület nyelve"

msgid "Set the payment gateway language"
msgstr "Állítsa be a fizetési átjáró nyelvét"

msgid "Skip receipt page"
msgstr "Nyugtaoldal kihagyása"

msgid "Pre-authorization"
msgstr "Előengedélyezés"

msgid "For pre-authorization, check the checkbox"
msgstr "Előengedélyezéshez jelölje be a jelölőnégyzetet"

#. translators: %s is the setting name.
msgid "%s updated successfully."
msgstr "%s sikeresen frissítve."

#. translators: 1: Field name, 2: Field name again.
msgid "%1$s cannot be empty. Please enter a %2$s."
msgstr "%1$s nem lehet üres. Kérjük, adjon meg egy %2$s értéket."

#. translators: %s is the field name.
msgid "A %s is currently saved."
msgstr "Jelenleg egy %s van mentve."

#. translators: 1: Field label, 2: Field label again.
msgid "No %1$s is currently saved. Please enter a %2$s."
msgstr "Jelenleg nincs mentve %1$s. Kérjük, adjon meg egy %2$s értéket."

msgid "Sandbox Merchant ID currently in use"
msgstr "Jelenleg használt Sandbox Merchant ID"

msgid "Sandbox Terminal ID currently in use"
msgstr "Jelenleg használt Sandbox Terminal ID"

msgid "Your store uses a currency that ecommerceconnect doesn't support yet."
msgstr "Az üzlete olyan pénznemet használ, amelyet az ecommerceconnect még nem támogat."

msgid "You forgot to fill your merchant ID."
msgstr "Elfelejtette megadni a merchant ID-t."

msgid "You forgot to fill your terminal ID."
msgstr "Elfelejtette megadni a terminal ID-t."

msgid ""
"To use eCommerceConnect as a payment provider, you need to fix the problems "
"below:"
msgstr "Az eCommerceConnect fizetési szolgáltatóként való használatához javítania kell az alábbi problémákat:"

msgid "Return to payments"
msgstr "Vissza a fizetésekhez"

#. translators: %1$s is the return URL, %2$s is the transaction ID or order
#. code shown in HTML.
msgid ""
"Please, enter this link into the notify url field in the merchant portal for "
"return customer back to your store after payment"
msgstr "Kérjük, illessze be ezt a linket a merchant portál Notify URL mezőjébe, hogy a vásárló fizetés után visszatérjen az üzletébe"

msgid "Gateway Disabled"
msgstr "Átjáró letiltva"

#. translators: %1$s and %2$s are opening and closing anchor or <strong> tags.
msgid ""
"Choose UAH as your store currency in %1$sGeneral Settings%2$s to enable the "
"eCommerceCcnnect Gateway."
msgstr "Válassza az UAH pénznemet az üzlethez a %1$sÁltalános beállítások%2$s menüben az eCommerceCcnnect Gateway engedélyezéséhez."

msgid "Purchase"
msgstr "Fizetés"

msgid "Back"
msgstr "Vissza"

msgid ""
"Thank you for your order, please click the button below to pay with "
"eCommerceConnect."
msgstr "Köszönjük a rendelést, kérjük kattintson az alábbi gombra az eCommerceConnect fizetéshez."

msgid "Capture via UPC"
msgstr "Rögzítés UPC-n keresztül"

msgid "Оплатити"
msgstr "Fizetés"

msgid "Запит не відбувся: "
msgstr "A kérés sikertelen volt: "

msgid "Captured via UPC Gateway"
msgstr "UPC Gateway-en keresztül rögzítve"

msgid "Capture success. Order moved to Processing"
msgstr "Sikeres rögzítés. A rendelés feldolgozás állapotba került"

msgid "Invalid response from UPC"
msgstr "Érvénytelen válasz az UPC-től"

msgid "Settings"
msgstr "Beállítások"

msgid "Support"
msgstr "Támogatás"

#. translators: %s is the anchor tag link to WooCommerce download page.
msgid ""
"WooCommerce eCommerceConnect Gateway requires WooCommerce to be installed and "
"active. You can download %s here."
msgstr "A WooCommerce eCommerceConnect Gateway-hez telepített és aktív WooCommerce szükséges. A %s innen tölthető le."

msgid "eCommerceConnect payment method"
msgstr "eCommerceConnect fizetési mód"

msgid "Transaction Currency"
msgstr "Tranzakció pénzneme"

msgid "Select the currency to be used for this payment method (WooCommerce current: <strong>%s</strong>)"
msgstr "Válassza ki a fizetési módhoz használt pénznemet (WooCommerce aktuális pénznem: <strong>%s</strong>)"

msgid "Alternative display currency (AltCurrency)"
msgstr "Alternatív megjelenítési pénznem (AltCurrency)"

msgid "Used for displaying price in another currency (must be USD or EUR). Used only for visual purposes."
msgstr "Az ár másik pénznemben történő megjelenítésére szolgál (USD vagy EUR lehet). Kizárólag megjelenítési célra használatos."

msgid "Pay with eCommerceConnect (Debit/Credit Cards)"
msgstr "Fizessen eCommerceConnecttel (betéti/hitelkártyák)"

msgid "Enter a Gateway URL https://..."
msgstr "Adjon meg egy Gateway URL-t https://..."

msgid "This is the URL of the payment gateway where the payment form will be submitted."
msgstr "Ez a payment gateway URL-je, ahová a fizetési űrlap elküldésre kerül."

msgid "EUR Conversion Rate"
msgstr "EUR átváltási árfolyam"

msgid "Specify the conversion rate for EUR. Use dot (.) as decimal separator."
msgstr "Adja meg az EUR átváltási árfolyamát. Tizedeselválasztónak pontot (.) használjon."

msgid "USD Conversion Rate"
msgstr "USD átváltási árfolyam"

msgid "Specify the conversion rate for USD. Use dot (.) as decimal separator."
msgstr "Adja meg az USD átváltási árfolyamát. Tizedeselválasztónak pontot (.) használjon."

msgid "eCommerceConnect requires Payment Gateway URL to work"
msgstr "Az eCommerceConnect működéséhez Payment Gateway URL szükséges"
